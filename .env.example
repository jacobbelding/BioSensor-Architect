# LLM API Keys (at least one required)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# PubMed / NCBI E-utilities (optional — improves rate limits from 3/sec to 10/sec)
NCBI_API_KEY=your-ncbi-api-key

# Model configuration
DEFAULT_MODEL=gpt-4o

# Multi-round critique (default 1 = single pass, no critique)
DESIGN_ROUNDS=1

# ChromaDB (for future RAG integration)
CHROMA_PERSIST_DIR=./data/literature_index

# CrossRef polite pool email (for DOI resolution in bsa ingest)
CROSSREF_EMAIL=your-email@example.com
